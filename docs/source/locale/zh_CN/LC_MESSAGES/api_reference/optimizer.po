#: 8b3ee520347448f5ae77f67fabebd9ce of tensormesh.optimizer.oc.OCOptimizer:1
msgid "Optimality Criteria (OC) optimizer for topology optimization."
msgstr ""

#: 0c554eb63bfd4492ad80f1b0a64deea4 of tensormesh.optimizer.oc.OCOptimizer:3
msgid ""
"Similar interface to :obj:`torch.optim.Optimizer`, but specifically "
"designed for density-based topology optimization with volume constraints."
msgstr ""

#: 81c95d91c2304931ba1c9b247c3f9d10 of tensormesh.optimizer.oc.OCOptimizer:6
msgid "The OC update rule is:"
msgstr ""

#: 4336ed4f32d746ffa71977771a04c1d5 of tensormesh.optimizer.oc.OCOptimizer:8
msgid ""
"\\rho_{\\text{new}} = \\rho \\cdot B_e^{\\eta}\n"
"\n"
msgstr ""

#: 58b4bd0e8e9d4b48918144933dd2e588 of tensormesh.optimizer.oc.OCOptimizer:11
msgid "where:"
msgstr ""

#: 1bfd95eb05bd4e23abde387a62bc3e1d of tensormesh.optimizer.oc.OCOptimizer:13
msgid ""
"B_e = \\sqrt{\\frac{-\\frac{\\partial C}{\\partial \\rho}}{\\lambda "
"\\cdot \\frac{\\partial V}{\\partial \\rho}}}\n"
"\n"
msgstr ""

#: bf9638026b0b43f489f65760417d888f of tensormesh.optimizer.oc.OCOptimizer:16
msgid ""
":math:`\\lambda`: Lagrange multiplier (found by bisection to satisfy "
"volume constraint)"
msgstr ""

#: e92d0be6829d46b2a81af36d5eff7d87 of tensormesh.optimizer.oc.OCOptimizer:17
msgid ":math:`\\eta = 0.5`: damping exponent"
msgstr ""

