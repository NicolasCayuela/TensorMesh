msgstr ""

#: a604a04aa7ae46e6afe8a4f0e8f5ade8 of
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency:3
msgid "-\\Delta u = f \\quad (x, y)"
msgstr ""

#: 72d10c67dd474e828b3df56fbf9604c1 of
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency:7
msgid ""
"where :math:`(x_1,x_2)\\in  [0,1]^2`, with the boundary condition "
":math:`u(t, \\pm 1, \\pm 1) = 0`"
msgstr ""

#: 20edbf4c0ce449d1b66d4f5c061bc608 de867cdee27b4e63bebe50c8e0e7949f of
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency:10
#: tensormesh.dataset.equation.wave.WaveMultiFrequency:11
#, python-brace-format
msgid ""
"3D tensor of shape :math:`[N, K, K]` or 2D tensor of shape :math:`[K, "
"K]`, where :math:`N` is the number of samples, :math:`K` is the dimension"
" of the frequencies the coefficient of the wave equation, if ``None``, it"
" will be randomly generated by :math:`\\mu\\sim Unif([-1,1]^{K\\times "
"K})`"
msgstr ""

#: 11371e24b3384579b59a3e0f6ffee795 1d45f45eaf3348918714b959e3bf4b8b of
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency:14
#: tensormesh.dataset.equation.wave.WaveMultiFrequency:15
msgid ""
"the dimension of the frequencies, if ``a`` is not ``None``, this "
"parameter will be ignored if ``a`` is ``None``, it will be used to "
"generate the random ``a``"
msgstr ""

#: 71f05911c3c44171ab9c7686c3779233 of
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency:17
msgid "the poisson speed, default is :math:`1.0`"
msgstr ""

#: c260973db0e54468a73abf0f44399644 of
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency:19
msgid "the coefficient of the poisson equation, default is :math:`0.5`"
msgstr ""

#: a108c5860fb940478dfa096522813cd4 of
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency.source_term:1
msgid "Generate the poisson source function at each point in the domain"
msgstr ""

#: c49f3b64e11146158f75be18e1be9ef0 of
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency.source_term:3
#, python-brace-format
msgid ""
"f=\\frac{\\pi}{K^2} \\sum_{i,j=1}^{K} a_{ij} \\cdot (i^2 + j^2)^{r} "
"sin(\\pi ix) sin(\\pi jy)"
msgstr ""

#: 1b818c905cf74ac3b62316f7e529a2f3 22f6448b770c435b9719f77e26fb70f5
#: 458de298b76046ffa6c696927b12cc66 a84dd29a62494cfd894153a19b35741d of
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency.solution:7
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency.source_term:7
#: tensormesh.dataset.equation.wave.WaveMultiFrequency.initial_condition:7
#: tensormesh.dataset.equation.wave.WaveMultiFrequency.solution:7
msgid ""
"2D tensor of shape :math:`[|\\mathcal V|, 2]`, where  :math:`|\\mathcal "
"V|` is the number of vertices all the points must be in :math:`[0,1]^2`"
msgstr ""

#: 1b05ab5b620848eb8ebab556c296c9e2 of
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency.source_term:13
msgid ""
"**u0** -- 1D tensor of shape :math:`[|\\mathcal V|]` or 2D Tensor "
":math:`[N, |\\mathcal V|]`, where :math:`N` is the number of samples, "
":math:`|\\mathcal V|` is the number of vertices"
msgstr ""

#: 19de1d1cabd14e65acc18294be9d6884 7b21f6317ad141a98d5ee56131cf3316 of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency.solution:1
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency.solution:1
msgid "Generate the poisson solution function at each point in the domain"
msgstr ""

#: 50e14f4cd3f04084afd5f76200e50fa8 of
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency.solution:3
#, python-brace-format
msgid ""
"u(x, y) = \\frac{1}{\\pi\\cdot K^2} \\sum_{i,j=1}^{K} a_{ij} \\cdot (i^2 "
"+ j^2)^{r-1} sin(\\pi ix) sin(\\pi jy)"
msgstr ""

#: 905bf22cd4d747718262405538658812 of
#: tensormesh.dataset.equation.poisson.PoissonMultiFrequency.solution:11
msgid ""
"**u** -- 1D tenor of shape :math:`[|\\\\mathcal V|]` or :math:`[N, "
"|\\\\mathcal V|]`, where :math:`N` is the number of samples, "
":math:`|\\\\mathcal V|` is the number of vertices"
msgstr ""

#: 1647ab904dd348aca3de4511deed3f92 of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency:1
msgid "Multi-frequency heat equation, with :math:`0` boundary condition"
msgstr ""

#: 75868fb4b13f49d3a033503e1e1ae8bb of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency:4
#, python-brace-format
msgid "\\frac{\\partial u }{\\partial t} = \\Delta u"
msgstr ""

#: ef7fe1c939704f4c96ccaf078fbcf03a of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency:8
msgid ""
"where :math:`t \\in [0,T],\\quad(x_1,x_2)\\in  [-1,1]^2`, with the "
"boundary condition :math:`u(t, \\pm 1, \\pm 1) = 0`"
msgstr ""

#: 9764e8e238ba4966afb6e8ca59c6f39d of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency:11
msgid ""
"2D tensor of shape :math:`[N, d]` or 1D tensor of shape :math:`[d]`, "
"where :math:`N` is the number of samples, :math:`d` is the dimension of "
"the frequencies the coefficient of the heat equation, if ``None``, it "
"will be randomly generated by :math:`\\mu\\sim Unif([-1,1]^d)`"
msgstr ""

#: 5a590df99e9d40338d7bcd243700eafe of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency:15
msgid ""
"the dimension of the frequencies, if ``mu`` is not ``None``, this "
"parameter will be ignored if ``mu`` is ``None``, it will be used to "
"generate the random ``mu``"
msgstr ""

#: 7b2a79a509194d73a86023a02e05f503 of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency.initial_condition:1
msgid "Generate the heat source function at each point in the domain"
msgstr ""

#: e418b79932884cb991f57cae91b58904 of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency.initial_condition:3
#, python-brace-format
msgid ""
"u(0,x_1,x_2,\\mu) = -\\frac{1}{d}\\sum_{m=1}^d  \\mu_m sin(\\pi m "
"x_1)sin(\\pi m x_2)/\\sqrt m"
msgstr ""

#: 17e2bf89bded4200b00b13d639d40a7d of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency.initial_condition:7
msgid ""
"2D tensor of shape :math:`[|\\mathcal V|, 2]`, where  :math:`|\\mathcal "
"V|` is the number of vertices all the points must be in :math:`[-1,1]^2`"
msgstr ""

#: b0db9b85333446f9bf14a7c207734d25 of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency.initial_condition:11
msgid ""
"1D tensor of shape :math:`[|\\mathcal V|]` or :math:`[N, |\\mathcal V|]`,"
" where :math:`N` is the number of samples, :math:`|\\mathcal V|` is the "
"number of vertices"
msgstr ""

#: c3fbe1a066564ca59f2d64382d1f925c of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency.solution:3
msgid ""
"u(t,x_1,x_2,\\mu) = -\\frac{1}{d}\\sum_{m=1}^d \\frac{\\mu_m}{\\sqrt{m}} "
"e^{-2m^2\\pi^2t} sin(\\pi m  x_1)sin(\\pi mx_2)"
msgstr ""

#: 3d14891a6ca547e685a7c89263038e95 of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency.solution:7
msgid ""
"2D tensor of shape :math:`[|\\mathcal V|, 2]`, where  :math:`|\\mathcal "
"V|` is the number of vertices"
msgstr ""

#: c0b61821ddeb4e8ba763e5e37dcd2c02 of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency.solution:9
msgid "the time"
msgstr ""

#: 5320e985b9e3403998dc0266aacef44d of
#: tensormesh.dataset.equation.heat.HeatMultiFrequency.solution:12
msgid ""
"**ut** -- 1D tensor of shape :math:`[|\\mathcal V|]` or :math:`[N, "
"|\\mathcal V|]`, where :math:`N` is the number of samples, "
":math:`|\\mathcal V|` is the number of vertices"
msgstr ""

#: 3b87d8d1196f44f49c97607f3ec61e04 of
#: tensormesh.dataset.equation.wave.WaveMultiFrequency:4
#, python-brace-format
msgid "u_{tt} = c^2 \\Delta u"
msgstr ""

#: 940f59c3b6be434db8288d30f246fa9d of
#: tensormesh.dataset.equation.wave.WaveMultiFrequency:8
msgid ""
"where :math:`t \\in [0,T],\\quad(x_1,x_2)\\in  [0,1]^2`, with the "
"boundary condition :math:`u(t, \\pm 1, \\pm 1) = 0`"
msgstr ""

#: 9f845b25f0194b2282d10e38e748c3a7 of
#: tensormesh.dataset.equation.wave.WaveMultiFrequency:18
msgid "the wave speed, default is :math:`1.0`"
msgstr ""

