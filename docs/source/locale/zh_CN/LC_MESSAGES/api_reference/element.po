#: 8caf94ac971e4039b37a08ad76381852 of
#: tensormesh.element.element.Element.get_basis_fns:1
msgid "Get the basis functions for this element type."
msgstr ""

#: 9f5c5f174f6d4f8781ad37fa786a4e76 of
#: tensormesh.element.element.Element.get_basis_fns:3
msgid ""
"Returns polynomial basis functions that interpolate values at the element"
" nodes. The basis functions have the Kronecker delta property, meaning "
"each basis function is 1 at its corresponding node and 0 at all other "
"nodes."
msgstr ""

#: c6d1c3d1768542aa8ab4aff3f959a1a5 of
#: tensormesh.element.element.Element.get_basis_fns:7
msgid ""
"For example, for a linear triangle element (order=1), returns 3 basis "
"functions corresponding to the 3 vertices. Each basis function is 1 at "
"one vertex and 0 at the other vertices."
msgstr ""

#: 679380cea8d74ade846391bd3cc1040f of
#: tensormesh.element.element.Element.get_basis_fns:11
msgid ""
"For higher orders, returns basis functions for both vertex and edge "
"nodes. The number and location of nodes depends on the specific element "
"type."
msgstr ""

#: 4b21f8b27fad4657935dae2db40fa13b of
#: tensormesh.element.element.Element.get_basis_fns:14
msgid ""
"The basis functions are returned as a Polynomials object containing the "
"polynomial coefficients and exponents. This allows efficient evaluation "
"and manipulation of the basis functions."
msgstr ""

#: 121ca26648bb40bf86ba0612bd1adbf7 of
#: tensormesh.element.element.Element.get_basis_fns:61
msgid "The order of the basis functions."
msgstr ""

#: a5e8e300877a4b79b33cbb52009c9d12 of
#: tensormesh.element.element.Element.get_basis_fns:65
msgid "The device to place the polynomial on."
msgstr ""

#: 9c993d350a84425190987d19100c82a9 of
#: tensormesh.element.element.Element.get_basis_fns:68
#, python-brace-format
msgid ""
"The basis functions of the element. Shape is :math:`[N_b]` where "
":math:`N_b` is the number of basis functions, with :math:`N_{vars}=D` "
"variables and :math:`N_{exp}=N_b` expansion terms."
msgstr ""

#: e39e775564ca47419366a69debdf9d94 of
#: tensormesh.element.element.Element.get_basis_grad_fns:1
msgid "Get the gradient of basis functions with respect to reference coordinates."
msgstr ""

#: 109adc72dd30439998db8ddd15b3b177 of
#: tensormesh.element.element.Element.get_basis_grad_fns:3
msgid ""
"For a basis function :math:`\\phi(x_1,\\ldots,x_n)`, computes the "
"gradient:"
msgstr ""

#: 67ab84e113c54ddabd99373e4e0b38ce of
#: tensormesh.element.element.Element.get_basis_grad_fns:5
#, python-brace-format
msgid ""
"\\nabla \\phi = \\left[\\frac{\\partial \\phi}{\\partial x_1}, \\ldots, "
"\\frac{\\partial \\phi}{\\partial x_n}\\right]"
msgstr ""

#: f9289a6a09d441e188342ce8e9d8e78f of
#: tensormesh.element.element.Element.get_basis_grad_fns:9
msgid ""
"The gradient is computed by taking the partial derivative of each basis "
"function with respect to each coordinate direction :math:`x_i` in the "
"reference element."
msgstr ""

#: 9f12660b16a6485cbea00fbf7088aa27 of
#: tensormesh.element.element.Element.get_basis_grad_fns:40
msgid "The order of the basis functions"
msgstr ""

#: 8949f6a5087b4f89baa36c69b7b35261 of
#: tensormesh.element.element.Element.get_basis_grad_fns:42
msgid "The float data type of the polynomial"
msgstr ""

#: 36d4bda8f0e2469a9f40e2cc6b75df71 of
#: tensormesh.element.element.Element.get_basis_grad_fns:44
msgid "The device to place the polynomial on"
msgstr ""

#: bd5785534e9846aa861e38ab06a14f83 of
#: tensormesh.element.element.Element.get_basis_grad_fns:47
msgid ""
"The gradient basis functions. Shape is :math:`[D, N_b]` where - :math:`D`"
" = spatial dimension - :math:`N_b` = number of basis functions - n_vars ="
" :math:`D` - n_terms = :math:`N_b`"
msgstr ""

#: 34bfebd8321345d98b1eb05737324e8d of
#: tensormesh.element.element.Element.eval_cell_jacobian:1
msgid "Evaluate the Jacobian matrix at quadrature points for each element."
msgstr ""

#: deb4b43d7a6f42f0b09db2a9c02fc4a0 of
#: tensormesh.element.element.Element.eval_cell_jacobian:3
msgid ""
"The Jacobian matrix represents the linear transformation from reference "
"coordinates to physical coordinates. It is computed by multiplying the "
"element coordinates by the gradients of the basis functions."
msgstr ""

#: f992968988a44c1e8abd7d35ccb1aa3f of
#: tensormesh.element.element.Element.eval_cell_jacobian:6
msgid "For each quadrature point q and element e, computes:"
