#: 806d93dd12f34425a4f51a161fef1560 of tensormesh.element.basis.tet_linspace:3
msgid ""
"The points are generated by first creating a regular grid in a cube, then"
" filtering points to keep only those inside the tetrahedron. For order k,"
" points are placed at:"
msgstr ""

#: 99189c3cec8c4568b47fb7603a6f3228 of tensormesh.element.basis.tet_linspace:8
msgid "Face points in a triangular pattern (order >= 3)"
msgstr ""

#: 0fc26c35efa54655a8f6a69283fad166 of tensormesh.element.basis.tet_linspace:25
msgid ""
"The points are generated by first creating a regular grid in a cube, then"
" filtering points to keep only those inside the tetrahedron. For order k,"
" points are placed at: - Vertices (order 1) - Edge points at 1/k, 2/k, "
"..., (k-1)/k along each edge (order >= 2) - Face points in a triangular "
"pattern (order >= 3) - Interior points (order >= 4)"
msgstr ""

#: 23054b4a3c1b4230b09d2bd2f6519989 of tensormesh.element.basis.pyr_linspace:1
msgid "Generate linearly spaced points inside a pyramid element."
msgstr ""

#: 1bac5b174fba4554b244c98aa12632fd of tensormesh.element.basis.pyr_linspace:3
msgid "The points are arranged in a structured pattern with:"
msgstr ""

#: 03dd06c4ae3a440aad0067de8245e820 of tensormesh.element.basis.pyr_linspace:5
msgid "Vertex points (order >= 1)"
msgstr ""

#: 94b958d3ab3e44b19c4ff60ed393ab48 of tensormesh.element.basis.pyr_linspace:6
msgid "Edge points in a linear pattern (order >= 2)"
msgstr ""

#: dfdfec1f317b45728812935a6ba31772 of tensormesh.element.basis.pyr_linspace:7
msgid "Face points in a triangular/quadrilateral pattern (order >= 3)"
msgstr ""

#: c5dbc1af60ce4de38243b6c7cd5ef362 of tensormesh.element.basis.pyr_linspace:12
msgid ""
"The pyramid element has a square base and triangular faces meeting at an "
"apex. The points are distributed in a tensor-product pattern that gets "
"narrower towards the apex."
msgstr ""

#: 67be1140040c443b9f8acbe16119f416 of tensormesh.element.basis.pyr_linspace:16
msgid "The number of points follows the pattern:"
msgstr ""

#: 912375b9009142c38a08a8628e38f235 of tensormesh.element.basis.pyr_linspace:18
#, python-brace-format
msgid ""
"N_{points} = \\begin{cases}\n"
"    \\frac{(n+1)(n+2)(2n+3)}{6} & \\text{if include_boundary=True} \\\\\n"
"    \\frac{(n-1)(n)(2n-3)}{6} & \\text{if include_boundary=False}\n"
"\\end{cases}"
msgstr ""

#: 417604c7d520459085541c7eab30d67c of tensormesh.element.basis.pyr_linspace:27
msgid ""
"The points are arranged in layers from bottom to top, with each layer "
"having a square pattern that reduces in size towards the apex."
msgstr ""

#: c44718262be04e5692567e5cd3c370f3 of tensormesh.element.basis.pri_linspace:1
msgid "Generate evenly spaced points inside a triangular prism."
msgstr ""

#: bb6b1c9f12c24edabdb66de38eae4233 of tensormesh.element.basis.pri_linspace:3
msgid ""
"The points are generated by first creating a regular grid in a "
"hexahedron, then filtering points to keep only those inside the prism. "
"For order k, points are placed at:"
msgstr ""

#: 2c03817abf814fd5ace74ff1152e8252 of tensormesh.element.basis.pri_linspace:8
msgid ""
"Face points in a triangular pattern on triangular faces and rectangular "
"pattern on quad faces (order >= 3)"
msgstr ""

#: e1f307e4fafe421985a1fcbecf50ee07 of tensormesh.element.basis.pri_linspace:15
#, python-brace-format
msgid ""
"N_{points} = \\begin{cases}\n"
"    \\frac{(n+1)^2(n+2)}{2} & \\text{if include_boundary=True} \\\\\n"
"    \\frac{(n-1)^2(n)}{2} & \\text{if include_boundary=False}\n"
"\\end{cases}"
msgstr ""

#: 8fe1e1ebbd3c411e919dcf84768c90a6 of tensormesh.element.basis.pri_linspace:24
msgid ""
"The points are arranged in triangular layers from bottom to top, with "
"each layer having the same triangular pattern."
msgstr ""

