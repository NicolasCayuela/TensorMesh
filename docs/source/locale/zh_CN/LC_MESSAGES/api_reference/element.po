#: 11ac42d9c203409c88178be73fc8956d of
#: tensormesh.element.element.Element.reorder:1
msgid ""
"Reorder element connectivity between **TensorMesh internal ordering** and"
" **Gmsh/VTK ordering**."
msgstr ""

#: 3b40b849f3e842cb81803b6a4cccc3c0 of
#: tensormesh.element.element.Element.reorder:3
msgid ""
"TensorMesh stores connectivity for some tensor-product elements (e.g. "
"Quad, Hex) in a **lexicographic** node order that matches the basis / "
"tensor-product polynomial layout. However, file formats like **VTK/VTU** "
"(and Gmsh conventions) expect a different ordering."
msgstr ""

#: 1671b63eb99245e881ceb0cb14458942 of
#: tensormesh.element.element.Element.reorder:7
msgid ""
"This helper provides a single, centralized conversion point so that: - "
"internal FEM kernels always see TensorMesh ordering - IO / visualization "
"(VTK/VTU) can export in Gmsh/VTK ordering"
msgstr ""

