#: tensormesh.assemble.builtin.MassElementAssembler:7
#: tensormesh.assemble.builtin.const_node_assembler:5
#: tensormesh.assemble.builtin.func_node_assembler:6
msgid "**Weak Form:**"
msgstr ""

#: b74d77a0b6a44ef2bdf43611a6d34e46 of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:9
msgid ""
"Given the Laplace equation :math:`-\\nabla \\cdot (\\kappa \\nabla u) = "
"f`, the weak form is:"
msgstr ""

#: 78f15b5d2ae243bcb1f75d600eb89feb of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:11
#, python-brace-format
msgid ""
"\\int_{\\Omega} \\kappa \\nabla u \\cdot \\nabla v \\, \\mathrm{d}\\Omega"
" = \\int_{\\Omega} f v \\, \\mathrm{d}\\Omega"
msgstr ""

#: 6e7e0edf1521407189f08847b04e5b39 of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:15
msgid "**Element Stiffness Matrix:**"
msgstr ""

#: 2611a34650644554be37ca0737946706 of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:17
msgid "For each element :math:`K`, the local stiffness matrix entry is:"
msgstr ""

#: 0a97df4bef40428d8795a2c6e29a6b06 of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:19
#, python-brace-format
msgid ""
"K_{ij}^e = \\int_{\\Omega^e} \\nabla N_i \\cdot \\nabla N_j \\, "
"\\mathrm{d}\\Omega"
msgstr ""

#: bfabbb62f43b4a1cb0706cb3d8a536a1 fe86459036b14ba0994e095810596915 of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:23
#: tensormesh.assemble.builtin.MassElementAssembler:20
msgid "where :math:`N_i, N_j` are the shape functions."
msgstr ""

#: b9424548d3c44f599b97191b9eb7f676 of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:25
msgid "**Implementation:**"
msgstr ""

#: 0017482087de479a9e4af5a6667d3ea3 of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:27
msgid ""
"The ``forward`` method computes the integrand :math:`\\nabla N_i \\cdot "
"\\nabla N_j` at each quadrature point, which is then integrated by the "
"base class."
msgstr ""

#: 3dcaa312c85245a591d4a4aa6e8c5e85 4a103e6163b94ffd905d37b1ee10505d
#: 4e09197041e0407194e1592d1004db90 78219fe975ad4459a2a46e3bb92c5297
#: 81df5b7c678947db87b7fd9b04935af9 d29d1685b04d4902b47c42ba572dc301
