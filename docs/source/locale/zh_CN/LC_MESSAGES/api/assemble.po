#: 7b3f18efb0c74da29dd43efb39767d08 of
#: tensormesh.assemble.builtin.MassElementAssembler:1
msgid "Mass Element Assembler."
msgstr ""

#: ca022759350b4d9d9b53db5ac5d10db7 of
#: tensormesh.assemble.builtin.MassElementAssembler:3
msgid ""
"Assembles the mass matrix for finite element discretization. The mass "
"matrix represents the :math:`L^2` inner product and is essential for "
"time-dependent problems, eigenvalue problems, and :math:`L^2` projection."
msgstr ""

#: 09b839aab9b64808a15bb0f01bfa049b of
#: tensormesh.assemble.builtin.MassElementAssembler:9
#, python-brace-format
msgid ""
"The mass matrix arises from terms like :math:`\\int_\\Omega u \\, v \\, "
"\\mathrm{d}\\Omega` in the weak formulation."
msgstr ""

#: 5518f25d33e54c8abfceb2c73a56cc25 of
#: tensormesh.assemble.builtin.MassElementAssembler:12
msgid "**Element Mass Matrix:**"
msgstr ""

#: 6c1dd7c7c34644dca7172f0c494c3260 of
#: tensormesh.assemble.builtin.MassElementAssembler:14
msgid "For each element :math:`K`, the local mass matrix entry is:"
msgstr ""

#: a084100204484e1f903cca71da7b867f of
#: tensormesh.assemble.builtin.MassElementAssembler:16
#, python-brace-format
msgid "M_{ij}^e = \\int_{\\Omega^e} N_i \\, N_j \\, \\mathrm{d}\\Omega"
msgstr ""

#: ecf0c66b70544c75bf1f823b8f74ebe4 of
#: tensormesh.assemble.builtin.MassElementAssembler:22
msgid "**Applications:**"
msgstr ""

#: 1440be44d25b418da9840ee77e21711f of
#: tensormesh.assemble.builtin.MassElementAssembler:24
msgid "Time-dependent PDEs (heat equation, wave equation)"
msgstr ""

#: 758ce5c7fba34f1199a8c37c47342947 of
#: tensormesh.assemble.builtin.MassElementAssembler:25
#, python-brace-format
msgid ""
":math:`L^2` error computation: :math:`\\|u - u_h\\|_{L^2}^2 = (u-u_h)^T M"
" (u-u_h)`"
msgstr ""

#: d852bf52c5c942b6b6cd6b4f4707e3f5 of
#: tensormesh.assemble.builtin.MassElementAssembler:26
msgid "Eigenvalue problems: :math:`K u = \\lambda M u`"
msgstr ""

#: 129b256cecbe49bab94465892c81c4fc of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:1
msgid "Linear Elasticity Element Assembler."
msgstr ""

#: 8fdd6ba64bc344308568ff7ba36aba73 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:3
msgid ""
"Assembles the stiffness matrix for linear elastic materials based on "
"Hooke's law. Suitable for small deformation analysis of isotropic "
"materials."
msgstr ""

#: e0c7d513cf174263a3416ef805546ea7 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:6
msgid "**Constitutive Law (Hooke's Law):**"
msgstr ""

#: 000b560713b54c26aa838bbff5699fb5 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:8
msgid "The stress-strain relationship for isotropic linear elasticity:"
msgstr ""

#: 877b89c18e3e461db3da54bb9dd9c2f0 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:10
#, python-brace-format
msgid "\\boldsymbol{\\sigma} = \\mathbf{C} : \\boldsymbol{\\varepsilon}"
msgstr ""

#: 08e929fde4ae425ea2a05c4c8301b022 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:14
#, python-brace-format
msgid "where the elasticity tensor :math:`\\mathbf{C}` is defined by:"
msgstr ""

#: 349b957669df4b4caaf0185e74ae467a of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:16
#, python-brace-format
msgid ""
"C_{ijkl} = \\lambda \\delta_{ij} \\delta_{kl} + \\mu "
"(\\delta_{ik}\\delta_{jl} + \\delta_{il}\\delta_{jk})"
msgstr ""

#: a7c459db0dc84351b581633b78d12496 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:20
msgid "**Lamé Parameters:**"
msgstr ""

#: f0803ee15cd3453fa07e767e97d5a7b5 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:22
#, python-brace-format
msgid ""
"\\lambda = \\frac{E \\nu}{(1+\\nu)(1-2\\nu)}, \\quad \\mu = "
"\\frac{E}{2(1+\\nu)}"
msgstr ""

#: 5fa9b7fa3fed4bcab3020ff43b242035 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:26
msgid "where :math:`E` is Young's modulus and :math:`\\nu` is Poisson's ratio."
msgstr ""

#: b87894af8ec146d3829fa4fdec94c63f of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:28
msgid "**Strain Tensor:**"
msgstr ""

#: 7a13ff3e199f4627b2dfcdf920217f93 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:30
msgid "The infinitesimal strain tensor:"
msgstr ""

#: 5e0467d9f1d84577be160a7aac30526f of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:32
#, python-brace-format
msgid ""
"\\boldsymbol{\\varepsilon} = \\frac{1}{2}(\\nabla \\mathbf{u} + \\nabla "
"\\mathbf{u}^T)"
msgstr ""

#: c601aa691cf54fb1bbef630153800c88 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:38
#, python-brace-format
msgid ""
"\\int_{\\Omega} \\boldsymbol{\\sigma}(\\mathbf{u}) : "
"\\boldsymbol{\\varepsilon}(\\mathbf{v}) \\, \\mathrm{d}\\Omega\n"
"= \\int_{\\Omega} \\mathbf{f} \\cdot \\mathbf{v} \\, \\mathrm{d}\\Omega\n"
"+ \\int_{\\Gamma_N} \\mathbf{t} \\cdot \\mathbf{v} \\, \\mathrm{d}S"
msgstr ""

#: 4bf34fdb375f4603be1b92b137382b54 6599edd45448412fac2b0e74e7e458b5 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:44
#: tensormesh.assemble.builtin.NeoHookeanModel:19
msgid "**Strain Energy Density:**"
msgstr ""

#: 83a171b300434bb59ddd9ba9fbd718b1 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:46
#, python-brace-format
msgid ""
"\\Psi = \\frac{1}{2} \\boldsymbol{\\varepsilon} : \\mathbf{C} : "
"\\boldsymbol{\\varepsilon}\n"
"= \\frac{\\lambda}{2} (\\mathrm{tr}\\, \\boldsymbol{\\varepsilon})^2 + "
"\\mu \\, \\boldsymbol{\\varepsilon} : \\boldsymbol{\\varepsilon}"
msgstr ""

#: 0974e34ab94a4cc8b24f57db1253b941 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler:52
msgid ""
"E (float): Young's modulus. Default: 1.0 nu (float): Poisson's ratio "
"(must satisfy :math:`-1 < \\nu < 0.5`). Default: 0.3"
msgstr ""

#: 584a1b058fc14012aca876e6b23b5bd3 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler.element_energy:1
msgid "Compute strain energy density at a quadrature point."
msgstr ""

#: 34f5b6176ea1466d978ad6d9fcc57301 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler.element_energy:3
#, python-brace-format
msgid ""
"\\Psi = \\frac{\\lambda}{2} (\\mathrm{tr}\\, "
"\\boldsymbol{\\varepsilon})^2\n"
"+ \\mu \\, \\boldsymbol{\\varepsilon} : \\boldsymbol{\\varepsilon}"
msgstr ""

#: 37e1a8eaa31f4b858654088f7574f3ee of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler.element_energy:9
#, python-brace-format
msgid ""
"graddisplacement: Displacement gradient tensor :math:`\\nabla "
"\\mathbf{u}` of shape ``[dim, dim]``"
msgstr ""

#: 4223775405374c92ba26e4509566b02e 6ad79ccc2a264ae48c008172e9540fe7 of
#: tensormesh.assemble.builtin.LinearElasticityElementAssembler.element_energy:12
#: tensormesh.assemble.builtin.NeoHookeanModel.element_energy:11
msgid "Strain energy density (scalar)"
msgstr ""

#: 9b2322702e5e45e1a3fda3a056ec632b of
#: tensormesh.assemble.builtin.NeoHookeanModel:1
msgid "Neo-Hookean Hyperelastic Material Model."
msgstr ""

#: 71fb7ecef56c4c2d8837869ee124ae16 of
#: tensormesh.assemble.builtin.NeoHookeanModel:3
msgid ""
"A nonlinear hyperelastic constitutive model for large deformation "
"analysis. The Neo-Hookean model is the simplest hyperelastic model and "
"extends linear elasticity to the finite strain regime."
msgstr ""

#: 9048f504ae104e9796929ead23f84f4a of
#: tensormesh.assemble.builtin.NeoHookeanModel:7
msgid "**Deformation Gradient:**"
msgstr ""

#: f198d58b04ea405297a5f0650cea90af of
#: tensormesh.assemble.builtin.NeoHookeanModel:9
#, python-brace-format
msgid "\\mathbf{F} = \\mathbf{I} + \\nabla \\mathbf{u}"
msgstr ""

#: 221659ec46d34a26a702923f895b02d2 of
#: tensormesh.assemble.builtin.NeoHookeanModel:13
msgid "**Kinematic Quantities:**"
msgstr ""

#: b8ebcc9ebe1745039bbb8161a3db8f5c of
#: tensormesh.assemble.builtin.NeoHookeanModel:15
#, python-brace-format
msgid "Right Cauchy-Green tensor: :math:`\\mathbf{C} = \\mathbf{F}^T \\mathbf{F}`"
msgstr ""

#: c5062a01b4364ed4a0f56cb64f2f8045 of
#: tensormesh.assemble.builtin.NeoHookeanModel:16
#, python-brace-format
msgid ""
"First invariant: :math:`I_1 = \\mathrm{tr}(\\mathbf{C}) = "
"\\|\\mathbf{F}\\|_F^2`"
msgstr ""

#: 3bc0c01d689d479480ded11369cfe9e2 of
#: tensormesh.assemble.builtin.NeoHookeanModel:17
#, python-brace-format
msgid "Jacobian (volume ratio): :math:`J = \\det(\\mathbf{F})`"
msgstr ""

#: 712034f76dc048e5b12968fd378d2b8f c87c90108b984d669ace8b48b310bd18 of
#: tensormesh.assemble.builtin.NeoHookeanModel:21
#: tensormesh.assemble.builtin.NeoHookeanModel.element_energy:3
#, python-brace-format
msgid ""
"\\Psi = \\frac{\\mu}{2}(I_1 - d) - \\mu \\ln J + \\frac{\\lambda}{2}(\\ln"
" J)^2"
msgstr ""

#: 2505b4de40424dca906be476ca8543f3 of
#: tensormesh.assemble.builtin.NeoHookeanModel:25
msgid "where :math:`d` is the spatial dimension (2 or 3)."
msgstr ""

#: 7bf2d5b3180244578973f98fc7568119 of
#: tensormesh.assemble.builtin.NeoHookeanModel:27
msgid "**First Piola-Kirchhoff Stress:**"
msgstr ""

#: 233bba7e6c66480282d959b4e7b8e377 of
#: tensormesh.assemble.builtin.NeoHookeanModel:29
msgid ""
"\\mathbf{P} = \\frac{\\partial \\Psi}{\\partial \\mathbf{F}}\n"
"= \\mu \\mathbf{F} + (\\lambda \\ln J - \\mu) \\mathbf{F}^{-T}"
msgstr ""

#: a2ce2ddd3ad949e8ba6e855c1b0aabbf of
#: tensormesh.assemble.builtin.NeoHookeanModel:34
msgid "**Material Parameters:**"
msgstr ""

#: 9c5f170d23b740c1aedf71e217ce4f34 of
#: tensormesh.assemble.builtin.NeoHookeanModel:36
#, python-brace-format
msgid ""
"\\mu = \\frac{E}{2(1+\\nu)}, \\quad \\lambda = "
"\\frac{E\\nu}{(1+\\nu)(1-2\\nu)}"
msgstr ""

#: 2935e54f4aa0414aa8d72e831f87e739 of
#: tensormesh.assemble.builtin.NeoHookeanModel:41
msgid ""
"E (float): Young's modulus. Default: 1.0 nu (float): Poisson's ratio. "
"Default: 0.3"
msgstr ""

#: f7abf0facbfd41afb1d102042d1429ef of
#: tensormesh.assemble.builtin.NeoHookeanModel:44
msgid "Note:"
msgstr ""

#: 95c4c3d85a5a4e188df4ccd587ac7990 of
#: tensormesh.assemble.builtin.NeoHookeanModel:45
msgid "Requires :math:`J > 0` (no element inversion)"
msgstr ""

#: b3a0bcade755428287138deedc208687 of
#: tensormesh.assemble.builtin.NeoHookeanModel:46
msgid ""
"For nearly incompressible materials (:math:`\\nu \\to 0.5`), consider "
"using a mixed formulation to avoid volumetric locking"
msgstr ""

#: 2d2b4c8df891422aa673b4e745f9b688 of
#: tensormesh.assemble.builtin.NeoHookeanModel.element_energy:1
msgid "Compute Neo-Hookean strain energy density at a quadrature point."
msgstr ""

#: 2fb010eacdea4f25b554063c92b4b169 of
#: tensormesh.assemble.builtin.NeoHookeanModel.element_energy:8
#, python-brace-format
msgid ""
"graddisplacement: Displacement gradient :math:`\\nabla \\mathbf{u}` of "
"shape ``[dim, dim]``"
msgstr ""

#: 72b14bf66f4e46a2857642305503d41d of
#: tensormesh.assemble.builtin.NeoHookeanModel.energy:1
msgid "Compute total strain energy."
msgstr ""

#: 5d8c53d7e0244dcca135dc60bf13aacc of
#: tensormesh.assemble.builtin.NeoHookeanModel.energy:3
#, python-brace-format
msgid "\\Pi = \\int_{\\Omega} \\Psi(\\mathbf{F}) \\, \\mathrm{d}\\Omega"
msgstr ""

#: 80d667c7dfb848e4a9302213dcbbf7a6 of
#: tensormesh.assemble.builtin.NeoHookeanModel.energy:8
msgid "u (torch.Tensor): Displacement field of shape ``[n_nodes, dim]``"
msgstr ""

#: e9ad8320965547e7a6f66bfd043767d8 of
#: tensormesh.assemble.builtin.NeoHookeanModel.energy:11
msgid "torch.Tensor: Total strain energy (scalar)"
msgstr ""

#: 8e96c1fd691d46f7bd1f28884b417b2a of
#: tensormesh.assemble.builtin.J2Plasticity:1
msgid "J2 (von Mises) Plasticity Model with Isotropic Hardening."
msgstr ""

#: a25f8ec8eb8244bebefd72f19469b775 of
#: tensormesh.assemble.builtin.J2Plasticity:3
msgid ""
"Implements rate-independent J2 plasticity with linear isotropic hardening"
" using a return-mapping algorithm. This model is suitable for metals and "
"other ductile materials under monotonic or cyclic loading."
msgstr ""

#: 205356bb87164291aac220ce540e8878 of
#: tensormesh.assemble.builtin.J2Plasticity:7
msgid "**Yield Function (von Mises):**"
msgstr ""

#: cc36066a6bc34350b04464c55d7ff7f2 of
#: tensormesh.assemble.builtin.J2Plasticity:9
msgid ""
"f(\\boldsymbol{\\sigma}, \\alpha) = \\|\\mathbf{s}\\| - "
"\\sqrt{\\frac{2}{3}}(\\sigma_0 + H\\alpha) \\leq 0"
msgstr ""

#: 294c25e65d3e47f89eb9fe23fb6fe768 5db6eaef80f646f8b252588120107b65 of
#: tensormesh.assemble.builtin.ContactAssembler:19
#: tensormesh.assemble.builtin.J2Plasticity:13
msgid "where:"
msgstr ""

#: 28c411e77d354f94880c7a4861789acf of
#: tensormesh.assemble.builtin.J2Plasticity:15
#, python-brace-format
msgid ""
":math:`\\mathbf{s} = \\boldsymbol{\\sigma} - "
"\\frac{1}{3}\\mathrm{tr}(\\boldsymbol{\\sigma})\\mathbf{I}` is the "
"deviatoric stress"
msgstr ""

#: da3b8498ff14467e9b06eb34754312d0 of
#: tensormesh.assemble.builtin.J2Plasticity:16
msgid ":math:`\\sigma_0` is the initial yield stress"
msgstr ""

#: ce7a8719d7194543b8eac14269e25a42 of
#: tensormesh.assemble.builtin.J2Plasticity:17
msgid ":math:`H` is the hardening modulus"
msgstr ""

#: af46d0451357422d80dcfba0922fabf8 of
#: tensormesh.assemble.builtin.J2Plasticity:18
msgid ":math:`\\alpha` is the equivalent plastic strain (internal variable)"
msgstr ""

#: 4ea096e92b514b9a86ac7c5a31318a41 of
#: tensormesh.assemble.builtin.J2Plasticity:20
msgid "**Additive Strain Decomposition:**"
msgstr ""

#: add659b1b1bd4062beec4de04027e3d2 of
#: tensormesh.assemble.builtin.J2Plasticity:22
#, python-brace-format
msgid ""
"\\boldsymbol{\\varepsilon} = \\boldsymbol{\\varepsilon}^e + "
"\\boldsymbol{\\varepsilon}^p"
msgstr ""

#: 83d4e2801ccb44beb1d58cc82f8bab96 of
#: tensormesh.assemble.builtin.J2Plasticity:26
msgid "**Flow Rule (Associated):**"
msgstr ""

#: 0913576f06c24cbc97f3edb29153a859 of
#: tensormesh.assemble.builtin.J2Plasticity:28
msgid ""
"\\dot{\\boldsymbol{\\varepsilon}}^p = \\dot{\\gamma} \\frac{\\partial "
"f}{\\partial \\boldsymbol{\\sigma}}\n"
"= \\dot{\\gamma} \\frac{\\mathbf{s}}{\\|\\mathbf{s}\\|}"
msgstr ""

#: d7c68616715046bdaf14b111c8f0c19f of
#: tensormesh.assemble.builtin.J2Plasticity:33
msgid "**Hardening Law:**"
msgstr ""

#: bfe1feed60674b54bb28dd2f8b33c219 of
#: tensormesh.assemble.builtin.J2Plasticity:35
msgid "\\dot{\\alpha} = \\sqrt{\\frac{2}{3}} \\dot{\\gamma}"
msgstr ""

#: c5c6b11202414a84808fb85f89143225 of
#: tensormesh.assemble.builtin.J2Plasticity:39
msgid "**Return Mapping Algorithm:**"
msgstr ""

#: dc739eaf30c2422a9510a40dd0bb4299 of
#: tensormesh.assemble.builtin.J2Plasticity:41
#, python-brace-format
msgid ""
"Compute trial elastic stress: :math:`\\boldsymbol{\\sigma}^{tr} = "
"\\mathbf{C}:(\\boldsymbol{\\varepsilon} - "
"\\boldsymbol{\\varepsilon}^p_n)`"
msgstr ""

#: 73c7c7abc4254925aee3c7bd22e1cfb2 of
#: tensormesh.assemble.builtin.J2Plasticity:42
#, python-brace-format
msgid ""
"Check yield: :math:`f^{tr} = \\|\\mathbf{s}^{tr}\\| - "
"\\sqrt{2/3}(\\sigma_0 + H\\alpha_n)`"
msgstr ""

#: aa972af6dd744004ba15ce064c85380c of
#: tensormesh.assemble.builtin.J2Plasticity:43
#, python-brace-format
msgid "If :math:`f^{tr} \\leq 0`: elastic step, accept trial state"
msgstr ""

#: 266fda0a6cf84e98a757c3e782b20800 of
#: tensormesh.assemble.builtin.J2Plasticity:44
#, python-brace-format
msgid "If :math:`f^{tr} > 0`: plastic correction"
msgstr ""

#: 19ae8c650c4e499e8d9d08130b7d3672 of
#: tensormesh.assemble.builtin.J2Plasticity:46
msgid "\\Delta\\gamma = \\frac{f^{tr}}{2\\mu + \\frac{2}{3}H}"
msgstr ""

#: 22830f83854642258309f98ee366d591 of
#: tensormesh.assemble.builtin.J2Plasticity:50
msgid "**Algorithmic Incremental Potential:**"
msgstr ""

#: e1816616c65b4557ad155d26fd2ef9d0 of
#: tensormesh.assemble.builtin.J2Plasticity:52
