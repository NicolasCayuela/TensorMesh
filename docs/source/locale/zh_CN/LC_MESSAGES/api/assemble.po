#: 0acfe0baa8ec4d22b6ab1ad02ec9fc14 of
#: tensormesh.assemble.element_assembler.ElementAssembler:1
msgid ""
"The :obj:`ElementAssembler` is inheritated from "
":class:`torch:torch.nn.Module`. Therefore, all the operation from "
":class:`torch:torch.nn.Module` is applicable to :obj:`ElementAssembler`"
msgstr ""

#: 14fa575ba9174feebea3dd4bc46ff4de of
#: tensormesh.assemble.element_assembler.ElementAssembler:3
msgid ""
"You are not encouraged to build the ElementAssembler directly, instead, "
"you should use :meth:`torch_fem.assemble.ElementAssembler.from_mesh` or "
":meth:`torch_fem.assemble.ElementAssembler.from_assembler` to build the "
"ElementAssembler from a mesh"
msgstr ""

#: 5f9a30653adb47c7968c32067b4c37c3 of
#: tensormesh.assemble.element_assembler.ElementAssembler:5
msgid ""
"The output when calling the ElementAssembler is a sparse matrix, which is"
" the global galerkin matrix of shape :math:`\\mathbb "
"R_{\\text{sparse}}^{\\vert\\mathcal V\\vert, \\vert\\mathcal V\\vert}` or"
" :math:`\\mathbb R_{\\text{sparse}}^[\\vert\\mathcal V\\vert \\times  H, "
"\\vert\\mathcal V\\vert \\times  H]`,"
msgstr ""

#: fb5ff73650954bd79151dddc48ec775f of
#: tensormesh.assemble.element_assembler.ElementAssembler:6
msgid ""
"where :math:`H` is the number of degree of freedom per point, "
":math:`\\vert\\mathcal V\\vert` is the number of points."
msgstr ""

#: eac941dd2d124823834c2f2ba281898f of
#: tensormesh.assemble.element_assembler.ElementAssembler:8
msgid ""
"K \\overset{\\text{bsr matrix}}{\\leftarrow}\\hat K_\\text{global}\n"
"\n"
"\\hat K_{\\text{global}}^{nkl} = \\mathcal P_{\\mathcal E}^{nhij} \\hat "
"K_{\\text{local}}^{hklij}\n"
"\n"
"\\hat K_{ij} = \\int_\\Omega  f(u, v) \\text dv"
msgstr ""

#: 3fa0ae3d3ec74137bf8afbec9f119b34 of
#: tensormesh.assemble.element_assembler.ElementAssembler:17
msgid ""
":math:`f` is `forward` function which is defined by inheritating this "
"class"
msgstr ""

#: b1b387ffafee42f9bae08ab01d620add of
#: tensormesh.assemble.element_assembler.ElementAssembler:19
msgid ""
":math:`\\hat K_{\\text{global}}` : non zero value of the global galerkin "
"matrix, :math:`K_{\\text{global}}\\in \\mathbb R^{\\vert\\mathcal "
"E\\vert\\times  d\\times d}`"
msgstr ""

#: 955274c064c84385a1d10e1e73619190 of
#: tensormesh.assemble.element_assembler.ElementAssembler:20
msgid ""
":math:`\\hat K_{\\text{local}}` : local galerkin matrix for each element "
", :math:`K_{\\text{local}}\\in \\mathbb R^{\\vert\\mathcal C\\vert\\times"
" h\\times h\\times d\\times d}`"
msgstr ""

#: d6e4f3513ae64e13959419d9d2b4fdc6 of
#: tensormesh.assemble.element_assembler.ElementAssembler:21
msgid ""
":math:`\\mathcal P_{\\mathcal E}` : projection (assemble) tensor from "
":math:`\\hat K_{\\text{local}}` to :math:`\\hat K_{\\text{global}}, "
"`\\mathcal P_{\\mathcal E} \\in \\mathbb "
"R_{\\text{sparse}}^{\\vert\\mathcal E\\vert\\times \\vert\\mathcal "
"C\\vert\\times h\\times h}`"
msgstr ""

