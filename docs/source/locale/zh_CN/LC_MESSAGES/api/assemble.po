#: 30354ed7ac0f4a4fa4b7995b3505e2ff of
#: tensormesh.assemble.builtin.LaplaceElementAssembler:3
msgid ""
"Assembles the stiffness matrix for the Laplace operator (diffusion term)."
" This is the fundamental building block for solving elliptic PDEs such as"
" the Poisson equation, heat equation (steady-state), and other diffusion "
"problems."
msgstr ""

#: 08bab3d6bdff4fd5a3826ed6326ca64d 2f1fd1c144de4e6f94932c4dd78261dc
#: 63ded85d46324c45b0612d288aab05cb acefed4f47144e8f8437fc466b2257a7
#: f54a8cca3efd40228f6b63f06f1bb0f5 of
