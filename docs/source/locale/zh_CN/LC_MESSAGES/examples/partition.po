#: tensormesh.mesh.partition.partition_mesh:1
msgid "Partition a mesh into independent submeshes for parallel computation."
msgstr ""

#: 9f98ddf8de1c4e75871be7510edb39d2 of
#: tensormesh.mesh.partition.partition_mesh:3
msgid ""
"This function performs element-based domain decomposition, creating "
"``n_parts`` submeshes that can be processed independently (with ghost "
"node communication for boundary data exchange)."
msgstr ""

