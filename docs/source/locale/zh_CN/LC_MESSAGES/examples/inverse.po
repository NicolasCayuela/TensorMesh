#: ../../source/examples/inverse.rst:91 b036fd34687e4820ac509ec7334ba02b
#, python-brace-format
msgid ""
"E(\\rho) = E_{min} + \\rho^p (E_{max} - E_{min})\n"
"\n"
msgstr ""

#: ../../source/examples/inverse.rst:94 2c51eaf317c94adf80f2d687c4b5a918
msgid "where :math:`p = 3` is the penalty factor that promotes 0-1 solutions."
msgstr ""

