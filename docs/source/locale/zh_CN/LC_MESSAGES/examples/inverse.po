#: f3577c2fcfa94f4fa84d39ce3378cdc5 of tensormesh.optimizer.oc.OCOptimizer:1
msgid "Optimality Criteria (OC) optimizer for topology optimization."
msgstr ""

#: 6e73abab342b4476a06b3753f1dbea21 of tensormesh.optimizer.oc.OCOptimizer:3
msgid ""
"Similar interface to :obj:`torch.optim.Optimizer`, but specifically "
"designed for density-based topology optimization with volume constraints."
msgstr ""

#: 8c0abcdc2b7847faba2bfe27aa67951d of tensormesh.optimizer.oc.OCOptimizer:6
msgid "The OC update rule is:"
msgstr ""

#: 1b86a0ad7db64d5f94bbe71f2cffa81c of tensormesh.optimizer.oc.OCOptimizer:8
msgid ""
"\\rho_{\\text{new}} = \\rho \\cdot B_e^{\\eta}\n"
"\n"
msgstr ""

#: 4faaf88a8e344120a7bd0c3d60146462 of tensormesh.optimizer.oc.OCOptimizer:11
msgid "where:"
msgstr ""

#: 5b320445684d452d9708a6843a4883fb of tensormesh.optimizer.oc.OCOptimizer:13
msgid ""
"B_e = \\sqrt{\\frac{-\\frac{\\partial C}{\\partial \\rho}}{\\lambda "
"\\cdot \\frac{\\partial V}{\\partial \\rho}}}\n"
"\n"
msgstr ""

#: 246dee9ca71c46619f223d6dd5ea0be3 of tensormesh.optimizer.oc.OCOptimizer:16
msgid ""
":math:`\\lambda`: Lagrange multiplier (found by bisection to satisfy "
"volume constraint)"
msgstr ""

#: 67914b8e7fe94a0c84d1390172568445 of tensormesh.optimizer.oc.OCOptimizer:17
msgid ":math:`\\eta = 0.5`: damping exponent"
msgstr ""

