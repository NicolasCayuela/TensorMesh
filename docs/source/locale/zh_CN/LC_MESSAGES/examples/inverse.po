#: ../../source/examples/inverse.rst:101 019f396ed5da43428b1a7beec642f4ef
msgid ""
"\\frac{\\partial C}{\\partial \\rho_e} = -\\mathbf{u}_e^T "
"\\frac{\\partial \\mathbf{K}^e}{\\partial \\rho_e} \\mathbf{u}_e\n"
"\n"
msgstr ""

#: ../../source/examples/inverse.rst:104 50cd7742646b458cb0f9c029f95a61f2
msgid "For SIMP interpolation:"
msgstr ""

#: ../../source/examples/inverse.rst:106 a0ffba8cab7c48958f001f313ed37ae4
#, python-brace-format
msgid ""
"\\frac{\\partial C}{\\partial \\rho_e} = -p \\rho_e^{p-1} (E_{max} - "
"E_{min}) \\, \\mathbf{u}_e^T \\mathbf{K}_0^e \\mathbf{u}_e\n"
"\n"
msgstr ""

