"\\begin{aligned}\n"
"& \\mathbf{K}(\\rho)\\mathbf{u} = \\mathbf{F} \\quad "
"\\text{(equilibrium)} \\\\\n"
"& \\frac{1}{|\\Omega|} \\int_{\\Omega} \\rho \\, d\\Omega \\leq \\bar{v} "
"\\quad \\text{(volume constraint)} \\\\\n"
"& 0 < \\rho_{min} \\leq \\rho \\leq 1 \\quad \\text{(bounds)}\n"
"\\end{aligned}\n"
"\n"
msgstr ""

#: ../../source/examples/inverse.rst:89 fae5c17aafc049c4af81a8ad35d514b5
msgid "**SIMP Material Interpolation:**"
