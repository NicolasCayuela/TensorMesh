#: ../../source/examples/solid_mechanics.rst:18
#: 9795d2ceb3fb41d9afd64c5ede19b688
msgid "Linear elasticity is governed by the balance of linear momentum:"
msgstr ""

#: ../../source/examples/solid_mechanics.rst:20
#: d2cdf6d1c9864140a8136a04bdd7badd
#, python-brace-format
msgid "\\nabla \\cdot \\boldsymbol{\\sigma} + \\mathbf{f} = \\mathbf{0}"
msgstr ""

#: ../../source/examples/solid_mechanics.rst:24
#: 3c7e87ac03ba48548f2c8e9e30fd9580
#, python-brace-format
msgid ""
"where :math:`\\boldsymbol{\\sigma}` is the Cauchy stress tensor and "
":math:`\\mathbf{f}` is the body force."
msgstr ""

#: ../../source/examples/solid_mechanics.rst:26
#: 48beb6a2228040c78f83b30c5a92ff41
msgid "The constitutive relation (Hooke's Law) is:"
msgstr ""

#: ../../source/examples/solid_mechanics.rst:28
#: 38302bb685c64e94b77aad89072a6fca
#, python-brace-format
msgid "\\boldsymbol{\\sigma} = \\mathbf{C} : \\boldsymbol{\\varepsilon}"
msgstr ""

#: ../../source/examples/solid_mechanics.rst:32
#: 38e34232a3584f91abc9e99bbd06569e
#, python-brace-format
msgid ""
"where :math:`\\boldsymbol{\\varepsilon} = \\frac{1}{2}(\\nabla "
"\\mathbf{u} + \\nabla \\mathbf{u}^T)` is the infinitesimal strain tensor."
msgstr ""

#: ../../source/examples/solid_mechanics.rst:34
#: 735775eefd164f7f9e95e3c12d8d7be7
msgid "For isotropic materials:"
msgstr ""

#: ../../source/examples/solid_mechanics.rst:36
#: 4554be7fbbb64ba69dbc29c4aaf425f3
#, python-brace-format
msgid ""
"\\boldsymbol{\\sigma} = \\lambda \\, "
"\\text{tr}(\\boldsymbol{\\varepsilon}) \\mathbf{I} + 2\\mu "
"\\boldsymbol{\\varepsilon}"
msgstr ""

#: ../../source/examples/solid_mechanics.rst:40
#: 19b19119b5364952a225389b8195397d
msgid ""
"where :math:`\\lambda` and :math:`\\mu` are Lamé parameters related to "
"Young's modulus :math:`E` and Poisson's ratio :math:`\\nu`."
msgstr ""

