msgid ""
"This example solves the Poisson equation :math:`-\\Delta u = f` on a unit"
" cube domain :math:`\\Omega = [0, 1]^3` with zero Dirichlet boundary "
"conditions."
msgstr ""

#: ../../source/examples/poisson.rst:76 0d614a736d644b13aa191610e9d451c8
#, python-brace-format
msgid ""
"\\begin{aligned}\n"
"-\\Delta u &= f \\quad \\text{in } \\Omega \\\\\n"
"u &= 0 \\quad \\text{on } \\partial \\Omega\n"
"\\end{aligned}"
msgstr ""

#: ../../source/examples/poisson.rst:83 5abe7e105afe445583c67cd29613c942
msgid ""
